#!/bin/zsh

set -eux

# TODO: Research GNU Stow
dotfiles=dirname "$(realpath $0)"
cfgs=(
  '.clang-format'
  '.clangd'
  '.editorconfig'
  '.gitconfig'
  '.tmux.conf'
  '.zshrc'
)

for cfg in $cfgs; do
  rm -f $HOME/$cfg
  ln -s $dotfiles/$cfg $HOME/$cfg
  echo "Set symlink for $cfg"
done

# Git
brew install lazygit
git config --global core.pager delta
git config --global interactive.diffFilter 'delta --color-only'
git config --global delta.navigate true

# Tmux
brew install tmux
rm -rf ~/.tmux/plugins/tpm
git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
# TODO: tmux-sessionizer

# Oh-My-ZSH
brew install autojump eza
rm -rf $ZSH_CUSTOM/plugins/zsh-autosuggestions
git clone https://github.com/zsh-users/zsh-autosuggestions.git $ZSH_CUSTOM/plugins/zsh-autosuggestions

# General
brew install fd bat eth-p/software/bat-extras-batgrep fzf neofetch

# Neovim doesn't NEED to be a submodule, but making it a submodule would
# make the history cleaner

# Neovim
brew install neovim nvm
nvm install node # needed to install some LSPs
rm -rf ~/.config/nvim
git clone git@github.com:N1v3x2/nvim.git ~/.config/nvim

# TODO: Ghostty

# TODO: Aerospace

# TODO: Karabiner

# vim: ft=zsh
