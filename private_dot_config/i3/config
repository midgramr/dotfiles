# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $alt Mod1
set $super Mod4
set $mod Mod5

set $i3lockopts --inside-color=1b1b1b \
--ring-color=1b1b1b \
--insidever-color=1b1b1b \
--ringver-color=7daea3 \
--insidewrong-color=1b1b1b \
--ringwrong-color=e78a4e \
--line-color=282828 \
--keyhl-color=a9b665 \
--bshl-color=e78a4e \
--layout-color=d4be98 \
--time-color=d4be98 \
--verif-color=d4be98 \
--wrong-color=d4be98 \
--modif-color=d4be98 \
--greeter-color=d4be98 \
--time-str='%l:%M %p' \
--time-font=Overpass \
--date-font=Overpass \
--layout-font=Overpass \
--verif-font=Overpass \
--greeter-font=Overpass

# Font for window titles. Will also be used by the bar unless a different font
# is used in the bar {} block below.
font pango:Overpass 12

# Startup apps
exec firefox
exec wezterm
exec slack
exec obsidian
exec claude-desktop
exec copyq

# Color options
client.focused          #a89984 #a89984 #282828 #a89984 #a89984
client.focused_inactive #a89984 #a89984 #282828 #a89984 #a89984
client.unfocused        #1b1b1b #1b1b1b #ddc7a1 #1b1b1b #1b1b1b
client.urgent           #e78a4e #e78a4e #282828 #e78a4e #e78a4e
client.background       #282828

focus_on_window_activation focus

exec_always --no-startup-id picom --backend glx

# Start XDG autostart .desktop files using dex. See also
# https://wiki.archlinux.org/index.php/XDG_Autostart
exec --no-startup-id dex --autostart --environment i3

# The combination of xss-lock, nm-applet and pactl is a popular choice, so
# they are included here as an example. Modify as you see fit.

# xss-lock grabs a logind suspend inhibit lock and will use i3lock to lock the
# screen before suspend. Use loginctl lock-session to lock your screen.
exec --no-startup-id xss-lock --transfer-sleep-lock -- betterlockscreen --lock blur -- $i3lockopts

exec --no-startup-id betterlockscreen -w

# Use pactl to adjust volume in PulseAudio.
set $refresh_i3status killall -SIGUSR1 i3status
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status

# Select region to save to file
bindsym $mod+p exec maim --select ~/screenshots/$(date +%Y-%m-%d_%H-%M-%S).png

# Region select to clipboard
bindsym $mod+Shift+p exec maim --select | xclip -selection clipboard -t image/png

# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod

# move tiling windows via drag & drop by left-clicking into the title bar,
# or left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar

# start a terminal
bindsym $mod+Return exec wezterm

# kill focused window
bindsym $mod+q kill

# start dmenu (a program launcher)
bindsym $mod+d exec --no-startup-id rofi -show drun
# A more modern dmenu replacement is rofi:
# bindcode $mod+40 exec "rofi -modi drun,run -show drun"
# There also is i3-dmenu-desktop which only displays applications shipping a
# .desktop file. It is a wrapper around dmenu, so you need that installed.
# bindcode $mod+40 exec --no-startup-id i3-dmenu-desktop

# Change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# Move focused window
bindsym $mod+$super+h move left
bindsym $mod+$super+j move down
bindsym $mod+$super+k move up
bindsym $mod+$super+l move right

# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle

# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

# toggle tiling / floating
bindsym $mod+$super+space floating toggle

# change focus between tiling / floating windows
bindsym $mod+space focus mode_toggle

# focus the parent container
bindsym $mod+a focus parent

# browser
set $ws1 "1:Browser"
# terminal/intellij (stack)
set $ws2 "2:IDE"
# slack
set $ws3 "3:Slack"
# notes
set $ws4 "4:Notes"
# zoom
set $ws5 "5:Zoom"
set $ws6 "6:Misc"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6

bindsym $mod+$super+1 move container to workspace $ws1; workspace $ws1
bindsym $mod+$super+2 move container to workspace $ws2; workspace $ws2
bindsym $mod+$super+3 move container to workspace $ws3; workspace $ws3
bindsym $mod+$super+4 move container to workspace $ws4; workspace $ws4
bindsym $mod+$super+5 move container to workspace $ws5; workspace $ws5
bindsym $mod+$super+6 move container to workspace $ws6; workspace $ws6

bindsym $mod+Tab workspace back_and_forth

# Window assignments
assign [class="firefox_firefox"] $ws1
assign [class="org.wezfurlong.wezterm"] $ws2
assign [class="slack"] $ws3
assign [class="obsidian"] $ws4
assign [class="zoom"] $ws5

for_window [class="zoom" title="^Meeting$"] resize set 4800 2000, move position center, layout stacking
for_window [class="copyq"] move scratchpad
for_window [class="Claude"] move scratchpad

# Scratchpads
bindsym $mod+c [class="Claude"] scratchpad show
bindsym $mod+v [class="copyq"] scratchpad show

bindsym $mod+$super+c reload
bindsym $mod+$super+r restart
bindsym $mod+$super+e exit

bindsym $mod+$super+semicolon exec betterlockscreen --lock blur -- $i3lockopts

mode "resize" {
    bindsym j resize shrink width 10 px or 10 ppt
    bindsym k resize grow height 10 px or 10 ppt
    bindsym l resize shrink height 10 px or 10 ppt
    bindsym semicolon resize grow width 10 px or 10 ppt
    bindsym Escape mode "default"
}
bindsym $mod+r mode "resize"

bar {
    status_command i3status
    separator_symbol "  "
    tray_output none
    colors {
        background #1b1b1b
        statusline #ddc7a1
        focused_workspace #a89984 #a89984 #282828
        inactive_workspace #282828 #282828 #d4be98
        urgent_workspace #e78a4e #e78a4e #282828
        binding_mode #7daea3 #7daea3 #282828
    }
}
