export EDITOR=nvim

# Oh-My-ZSH config
export ZSH="$HOME/.oh-my-zsh"

# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="minimal"

# Update automatically without asking
zstyle ':omz:update' mode auto

plugins=(
    git
    eza
    vi-mode
)

source $ZSH/oh-my-zsh.sh
# Oh-My-ZSH config end

# Setup completions
fpath=(~/.zsh.d/ $HOME/.docker/completions $fpath)
autoload -U compinit
compinit

source "$(brew --prefix nvm)/nvm.sh"
export HOMEBREW_FORCE_VENDOR_RUBY=1
export HOMEBREW_NO_ENV_HINTS=1

export MANPAGER='nvim +Man! +"set so=99"'
export JAVA_HOME=$(/usr/libexec/java_home 2>/dev/null)

# fzf
# TODO: create zsh widget (?) to automatically become nvim process after exit
# NOTE: this could be done a in hacky way by repurposing the existing cmdline
# completion, but the tool's author suggested creating some custom binding
fg0='#d4be98'
bg0='#282828'
green='#a9b665'
bg_green='#34381b'
orange='#e78a4e'
gray='#a89984'
export FZF_DEFAULT_OPTS="--cycle --layout=reverse --highlight-line \
--gutter=' ' --pointer='>' --no-bold --no-scrollbar --height=~50% \
--color=fg:$fg0,bg:$bg0,hl:$green,fg+:$fg0,bg+:$bg_green,hl+:$green,\
info:$gray,prompt:$orange,pointer:$fg0,spinner:$green"
export FZF_CTRL_T_OPTS="--walker-skip .git,node_modules,target"
source <(fzf --zsh)

fzf-nvim() {
    tmux set -p cursor-style bar
    fd . | fzf --scheme=path --bind 'enter:become(nvim {})'
    tmux set -p cursor-style block
}

fzf-z() {
    tmux set -p cursor-style bar
    dir=$(fd -td . | fzf --scheme=path)
    if [[ -n $dir ]]; then
        z $dir
    fi
    tmux set -p cursor-style block
}

zle-line-pre-redraw() { zle reset-prompt; }

zle -N fzf-nvim
zle -N fzf-z
zle -N zle-line-pre-redraw
bindkey '^b' test-widget
bindkey '^f' fzf-nvim
bindkey '^z' fzf-z

# zoxide
export _ZO_FZF_OPTS="$FZF_DEFAULT_OPTS"
eval "$(zoxide init zsh)"

# cht.sh
CHTSH_QUERY_OPTIONS="T"

# zsh help utility
export HELPDIR=/usr/share/zsh/$ZSH_VERSION/help
unalias run-help
autoload run-help

# Kitty binaries
export PATH=$PATH:/Applications/kitty.app/Contents/MacOS

# Go binaries
export PATH=$PATH:~/go/bin

# Enable core dumps for Neovim dev
ulimit -c unlimited

alias bat='bat --theme-dark gruvbox-dark'
alias c='cht.sh'
alias d='docker'
alias dc='docker compose'
alias di='docker image'
alias db='docker build'
alias dr='docker run'
alias fd='fd -H -E .git'
alias help='run-help'

# TODO: make keybind for running nvim via fzf

source $(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh

