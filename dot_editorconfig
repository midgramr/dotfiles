root = true

[*]
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true
indent_size = 4
indent_style = space

[*.{html,css}]
indent_size = 2

[*.{js,jsx,mjs,ts,tsx,mts,json}]
indent_size = 2

[*.{conf,yaml,yml}]
indent_size = 2

[*.lua]
indent_size = 2

[{CMakeLists.txt,*.cmake}]
indent_size = 2

[Makefile]
indent_style = tab

[*.go]
indent_style = tab

[*.rasi]
indent_size = 2

# vim: ft=editorconfig
