#!/bin/bash

set -u

window_id="$(aerospace list-windows --all | rg 'Thunderbird.*Reminder' | cut -w -f1)"
workspace_name="$(aerospace list-workspaces --focused)"

aerospace move-node-to-workspace --fail-if-noop --focus-follows-window --window-id "$window_id" "$workspace_name"
if [[ $? != 0 ]]; then
    aerospace focus --window-id "$window_id"
fi

# vim: ft=bash
