#!/bin/bash

set -x -o pipefail

# High-level idea: on invocation, bring up an fzf prompt containing a list of
# 1. local branches (override remote branch if both exist)
# 2. remote branches
#
# If you hover over a branch with an associated worktree and press <C-d>, the
# worktree and associated tmux session with be deleted
#
# If you choose a branch with no worktree, a worktree + tmux session will be
# created and switched to
#
# If you choose a branch with a worktree (and thus a session), the session
# will be switched to
#
# NOTE: It's possible that a branch with a worktree doesn't have an associated
# tmux session (e.g., if created outside this tool). In that case, I'll need
# to check for and handle that edge case
#
# NOTE: this script will break if the remote gets changed in a repo
# Could maybe set the wt_dir to a hidden directory in the original working tree

WORKTREES_HOME="${XDG_STATE_HOME:-$HOME/.local/state}/worktrees"

print_help() {
    echo -e "Usage: fzf-worktrees [options]\n"
    echo "-c, --cwd     working directory to run this from"
    echo "-h, --help    show this help"
}

while (($# > 0)); do
    case $1 in
    -c | --cwd)
        cd "$2"
        shift
        shift
        ;;
    -h | --help)
        print_help
        exit 0
        ;;
    *)
        echo "Unknown argument $1"
        print_help
        exit 1
        ;;
    esac
done

pick_branch() {
    local branch="$(
        git branch -a --color=always | rg -v 'origin/HEAD' |
            fzf --tmux --ansi --border-label ' branches ' --info=hidden --no-sort \
                --bind 'ctrl-d:execute(
                    branch="$(echo {} | cut -w -f2)"
                    remote="$(git remote get-url origin | cut -d: -f2 | cut -d . -f1)"
                    worktree="$(git branch --list "$branch" --format "%(worktreepath)")"
                    session=" $remote/$branch"
                    if [[ -n "$worktree" ]]; then
                        git worktree remove --force "$worktree"
                        tmux kill-session -t "$session" &>/dev/null
                    fi
                )+reload(git branch -a --color=always | rg -v "origin/HEAD")' |
            cut -w -f2
    )"

    if [[ -z "$branch" || "$branch" == "$(git branch --show-current)" ]]; then
        return 2
    fi

    local branch_fmt='%(refname:short) %(if)%(worktreepath)%(then)%(worktreepath)%(else)none%(end)'
    local branches="$(git branch -a --format "$branch_fmt" | rg -v 'origin/HEAD')"

    # User selected a remote branch
    if echo "$branch" | rg -q "^remotes/"; then
        local local_branch="$(echo "$branch" | cut -d/ -f3-4)"
        if ! echo "$branches" | rg -q "$local_branch"; then
            git branch "$local_branch" -t "$branch"
        fi
        local branch="$local_branch"
    fi

    if ! echo "$branches" | rg -q -m 1 "$branch\\s"; then
        return 1
    fi

    echo "$branch"
}

# Remove slashes from branch name since they can't be used in filenames
setup_worktree() {
    local branch="$1"
    local repo_worktree_dir="$2"
    local existing_worktree="$(git branch --list "$branch" --format "%(worktreepath)")"
    if [[ -z "$existing_worktree" ]]; then
        local clean_branch="$(echo "$branch" | tr / -)"
        local worktree_dir="$repo_worktree_dir/$clean_branch"
        mkdir -p "$repo_worktree_dir"
        git worktree prune
        git worktree add "$worktree_dir" "$branch" &>/dev/null
        echo "$worktree_dir"
    else
        echo "$existing_worktree"
    fi
}

# Handle corresponding tmux sessions
switch_session() {
    local remote="$1"
    local branch="$2"
    local repo_worktree_dir="$3"
    local worktree_dir="$4"

    local session=" $remote/$branch"
    local session_file="$repo_worktree_dir/session"
    local existing_worktree="$(git branch --list "$branch" --format "%(worktreepath)")"

    if [[ ! -e "$session_file" ]]; then
        echo "$(tmux display -p '#S')" >"$session_file"
    fi

    if ! echo "$existing_worktree" | rg -q "$repo_worktree_dir"; then
        # If the branch's worktree can't be found in `repo_worktree_dir`
        # that means this is the tmux session associated with the original worktree
        local session="$(cat "$session_file")"
    fi

    if ! tmux has-session -t "$session" &>/dev/null; then
        tmux new-session -d -s "$session" -c "$worktree_dir"
    fi
    tmux switch-client -t "$session"
}

remote="$(git remote get-url origin | cut -d: -f2 | cut -d . -f1)"
worktree_group="$(echo $remote | tr / -)"
repo_worktree_dir="$WORKTREES_HOME/$worktree_group"

branch="$(pick_branch)"
case $? in
1) exit 1 ;;
2) exit 0 ;;
esac

worktree_dir="$(setup_worktree "$branch" "$repo_worktree_dir")"

switch_session "$remote" "$branch" "$repo_worktree_dir" "$worktree_dir"
